{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ToolDock",
  "version": "1.0.0",
  "identifier": "tooldock",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ToolDock",
        "width": 1024,
        "height": 768,
        "center": true,
        "decorations": false,
        "dragDropEnabled": false
      },
      {
        "label": "magnifier",
        "url": "index.html#/magnifier",
        "title": "Magnifier",
        "maximized": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "screenshot-selector",
        "url": "index.html#/screenshot-selector",
        "title": "Screenshot Selector",
        "maximized": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "compression": "lzma"
      }
    }
  }
}